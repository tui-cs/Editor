<Project>

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>

    <Authors>gui-cs</Authors>
    <Company>gui-cs</Company>
    <Copyright>Copyright (c) gui-cs and contributors</Copyright>

    <!--
      Base version for both NuGet packages. Tracks Terminal.Gui's stream:
      when latest TG stable is X.Y.Z, our develop base is X.(Y+1).0-develop or X.Y.(Z+1)-develop.
      Release workflow overrides via -p:Version=<computed>:
        - tag push v1.2.3        → 1.2.3
        - develop branch push    → 2.1.1-develop.<github.run_number>
        - workflow_dispatch      → input.version (verbatim)
    -->
    <Version>2.1.1-develop</Version>
    <PackageProjectUrl>https://github.com/gui-cs/Editor</PackageProjectUrl>
    <RepositoryUrl>https://github.com/gui-cs/Editor</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseFile>LICENSE</PackageLicenseFile>

    <!--
      Pinned Terminal.Gui version. CI / release workflows can override via -p:TerminalGuiVersion=<x>.

      TODO(gui-cs/Editor#132): the syntax-theme work (PR #134) consumes the code-token
      VisualRoles added in gui-cs/Terminal.Gui#5313 (PR for TG issue #5311). That TG change is
      not yet on a published develop pre-release, so this value must be bumped to the first
      `2.1.1-develop.<n>` build that contains #5313 before PR #134 leaves draft / CI can go green.
      Local verification until then: build TG from the #5313 branch and pass
      -p:TerminalGuiVersion=<that GitVersion> to dotnet build/run.
    -->
    <TerminalGuiVersion Condition="'$(TerminalGuiVersion)' == ''">2.1.1-develop.59</TerminalGuiVersion>
  </PropertyGroup>

  <ItemGroup>
    <None Include="$(MSBuildThisFileDirectory)LICENSE" Pack="true" PackagePath="" />
    <None Include="$(MSBuildThisFileDirectory)README.md" Pack="true" PackagePath="" />
  </ItemGroup>

</Project>
