<wpf:ResourceDictionary xml:space="preserve" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:s="clr-namespace:System;assembly=mscorlib" xmlns:ss="urn:shemas-jetbrains-com:settings-storage-xaml" xmlns:wpf="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
  <!--
    Team-shared ReSharper / Rider settings for gui-cs/Editor.
    Committed alongside .editorconfig. Edit in Rider via "Settings | Editor | Code Style"
    and "Settings | Editor | Code Cleanup", then "Save to: This Solution Team-Shared".

    Most C# style is in .editorconfig (dotnet format reads it). This file holds:
      - the Code Cleanup profile contributors run via `jb cleanupcode` and the Stop hook
      - ReSharper-specific knobs that have no .editorconfig equivalent
      - ReSharper inspection severities elevated to error so CI catches drift

    See CLAUDE.md "Coding standards" for the human-readable rules.
  -->

  <!-- =============================================================== -->
  <!-- Cleanup profile: "TG.Editor Full Cleanup"                        -->
  <!-- Used by `jb cleanupcode`, the Claude Code Stop hook, and CI.     -->
  <!--                                                                  -->
  <!-- MODERN FORMAT: ReSharper / Rider / `jb` 2024+ store each cleanup -->
  <!-- profile as ONE string holding a serialized <Profile> document.   -->
  <!-- The old per-task `…/=Name/CSReformatCode/@EntryIndexedValue`     -->
  <!-- key layout is silently ignored by 2026.1.1 (profile vanishes     -->
  <!-- from the IDE and `jb` can't resolve it). Edit this profile in    -->
  <!-- Rider via Settings | Editor | Code Cleanup, then "Save to: This  -->
  <!-- Solution Team-Shared" — Rider rewrites this string in-place.     -->
  <!--                                                                  -->
  <!-- Verbatim Terminal.Gui "Full Cleanup" (this repo adopts TG house  -->
  <!-- style) with ONE mandated divergence: the auto-property rewrites  -->
  <!-- CSUseAutoProperty (set False) and CSMakeAutoPropertyGetOnly      -->
  <!-- (removed) are OFF — they destroy intentional C# 13 `field`-backed -->
  <!-- properties (CLAUDE.md "Properties"; ReSharper bug warning).      -->
  <!--                                                                  -->
  <!-- Deliberately ABSENT (and must stay absent), matching TG:         -->
  <!--  • CSUpdateFileHeader — with no header template configured it    -->
  <!--    STRIPS leading comments, including the mandated               -->
  <!--    `// Claude - <model>` / `// CoPilot - <model>` attribution    -->
  <!--    headers (CLAUDE.md "Testing convention").                     -->
  <!--  • CSReorderTypeMembers — TG keeps member reordering in a        -->
  <!--    separate "File Layout" profile so routine cleanup never       -->
  <!--    churns the hand-curated layout / field placement              -->
  <!--    (CLAUDE.md "Type and file layout", "Field placement").        -->
  <!-- =============================================================== -->
  <s:String x:Key="/Default/CodeStyle/CodeCleanup/RecentlyUsedProfile/@EntryValue">TG.Editor Full Cleanup</s:String>
  <s:String x:Key="/Default/CodeStyle/CodeCleanup/SilentCleanupProfile/@EntryValue">TG.Editor Full Cleanup</s:String>
  <s:String x:Key="/Default/CodeStyle/CodeCleanup/Profiles/=TG_002EEditor_0020Full_0020Cleanup/@EntryIndexedValue">&lt;?xml version="1.0" encoding="utf-16"?&gt;&lt;Profile name="TG.Editor Full Cleanup"&gt;&lt;AspOptimizeRegisterDirectives&gt;True&lt;/AspOptimizeRegisterDirectives&gt;&lt;CSCodeStyleAttributes ArrangeVarStyle="True" ArrangeTypeAccessModifier="True" ArrangeTypeMemberAccessModifier="True" SortModifiers="True" ArrangeArgumentsStyle="True" RemoveRedundantParentheses="True" AddMissingParentheses="True" ArrangeBraces="True" ArrangeAttributes="True" ArrangeCodeBodyStyle="True" ArrangeTrailingCommas="True" ArrangeObjectCreation="True" ArrangeDefaultValue="True" ArrangeNamespaces="True" ArrangeNullCheckingPattern="True" /&gt;&lt;RemoveCodeRedundanciesVB&gt;True&lt;/RemoveCodeRedundanciesVB&gt;&lt;Xaml.RedundantFreezeAttribute&gt;True&lt;/Xaml.RedundantFreezeAttribute&gt;&lt;Xaml.RemoveRedundantModifiersAttribute&gt;True&lt;/Xaml.RemoveRedundantModifiersAttribute&gt;&lt;Xaml.RemoveRedundantNameAttribute&gt;True&lt;/Xaml.RemoveRedundantNameAttribute&gt;&lt;Xaml.RemoveRedundantResource&gt;True&lt;/Xaml.RemoveRedundantResource&gt;&lt;Xaml.RemoveRedundantCollectionProperty&gt;True&lt;/Xaml.RemoveRedundantCollectionProperty&gt;&lt;Xaml.RemoveRedundantAttachedPropertySetter&gt;True&lt;/Xaml.RemoveRedundantAttachedPropertySetter&gt;&lt;Xaml.RemoveRedundantStyledValue&gt;True&lt;/Xaml.RemoveRedundantStyledValue&gt;&lt;Xaml.RemoveRedundantNamespaceAlias&gt;True&lt;/Xaml.RemoveRedundantNamespaceAlias&gt;&lt;Xaml.RemoveForbiddenResourceName&gt;True&lt;/Xaml.RemoveForbiddenResourceName&gt;&lt;Xaml.RemoveRedundantGridDefinitionsAttribute&gt;True&lt;/Xaml.RemoveRedundantGridDefinitionsAttribute&gt;&lt;Xaml.RemoveRedundantUpdateSourceTriggerAttribute&gt;True&lt;/Xaml.RemoveRedundantUpdateSourceTriggerAttribute&gt;&lt;Xaml.RemoveRedundantBindingModeAttribute&gt;True&lt;/Xaml.RemoveRedundantBindingModeAttribute&gt;&lt;Xaml.RemoveRedundantGridSpanAttribut&gt;True&lt;/Xaml.RemoveRedundantGridSpanAttribut&gt;&lt;XMLReformatCode&gt;True&lt;/XMLReformatCode&gt;&lt;RemoveCodeRedundancies&gt;True&lt;/RemoveCodeRedundancies&gt;&lt;CSUseAutoProperty&gt;False&lt;/CSUseAutoProperty&gt;&lt;CSMakeFieldReadonly&gt;True&lt;/CSMakeFieldReadonly&gt;&lt;CSArrangeQualifiers&gt;True&lt;/CSArrangeQualifiers&gt;&lt;CSFixBuiltinTypeReferences&gt;True&lt;/CSFixBuiltinTypeReferences&gt;&lt;HtmlReformatCode&gt;True&lt;/HtmlReformatCode&gt;&lt;VBOptimizeImports&gt;True&lt;/VBOptimizeImports&gt;&lt;VBShortenReferences&gt;True&lt;/VBShortenReferences&gt;&lt;CSOptimizeUsings&gt;&lt;OptimizeUsings&gt;True&lt;/OptimizeUsings&gt;&lt;/CSOptimizeUsings&gt;&lt;CSShortenReferences&gt;True&lt;/CSShortenReferences&gt;&lt;VBReformatCode&gt;True&lt;/VBReformatCode&gt;&lt;VBFormatDocComments&gt;True&lt;/VBFormatDocComments&gt;&lt;CSReformatCode&gt;True&lt;/CSReformatCode&gt;&lt;CSharpFormatDocComments&gt;True&lt;/CSharpFormatDocComments&gt;&lt;FormatAttributeQuoteDescriptor&gt;True&lt;/FormatAttributeQuoteDescriptor&gt;&lt;/Profile&gt;</s:String>

  <!-- IMPORTANT: CSUseAutoProperty is OFF.                                                  -->
  <!-- ReSharper has bugs around the C# 13 `field` keyword: it offers / applies              -->
  <!-- "convert to auto-property" rewrites that destroy intentional `field`-backed           -->
  <!-- properties. We hand-write `field`-backed properties (see CLAUDE.md "Properties");     -->
  <!-- cleanup must not undo that work.                                                       -->

  <!-- =============================================================== -->
  <!-- Code style — items without a .editorconfig equivalent.          -->
  <!-- =============================================================== -->

  <!-- var: built-ins yes, everything else no. Mirrors .editorconfig. -->
  <s:String x:Key="/Default/CodeStyle/CSharpVarKeywordUsage/ForBuiltInTypes/@EntryValue">UseVar</s:String>
  <s:String x:Key="/Default/CodeStyle/CSharpVarKeywordUsage/ForSimpleTypes/@EntryValue">UseExplicitType</s:String>
  <s:String x:Key="/Default/CodeStyle/CSharpVarKeywordUsage/ForOtherTypes/@EntryValue">UseExplicitType</s:String>

  <!-- Expression-bodied members: properties yes, methods no (see CLAUDE.md). -->
  <s:String x:Key="/Default/CodeStyle/CSharpCodeStyle/PreferredMethodBodyStyle/@EntryValue">block_body</s:String>
  <s:String x:Key="/Default/CodeStyle/CSharpCodeStyle/PreferredAccessorBodyStyle/@EntryValue">expression_body</s:String>
  <s:String x:Key="/Default/CodeStyle/CSharpCodeStyle/PreferredConstructorBodyStyle/@EntryValue">block_body</s:String>
  <s:String x:Key="/Default/CodeStyle/CSharpCodeStyle/PreferredOperatorBodyStyle/@EntryValue">block_body</s:String>
  <s:String x:Key="/Default/CodeStyle/CSharpCodeStyle/PreferredLambdaBodyStyle/@EntryValue">expression_body</s:String>

  <!-- Object/collection initializers: prefer collection expressions [...] -->
  <s:String x:Key="/Default/CodeStyle/CSharpCodeStyle/PreferredObjectCreationStyle/@EntryValue">target_typed</s:String>

  <!-- Blank lines around control blocks (CLAUDE.md "Blank line before return/break"). -->
  <s:Int64 x:Key="/Default/CodeStyle/CSharpFormat/BLANK_LINES_AROUND_REGION/@EntryValue">1</s:Int64>
  <s:Int64 x:Key="/Default/CodeStyle/CSharpFormat/BLANK_LINES_INSIDE_REGION/@EntryValue">1</s:Int64>
  <s:String x:Key="/Default/CodeStyle/CSharpFormat/PLACE_SIMPLE_ACCESSOR_ON_SINGLE_LINE/@EntryValue">True</s:String>
  <s:String x:Key="/Default/CodeStyle/CSharpFormat/SIMPLE_EMBEDDED_STATEMENT_STYLE/@EntryValue">DO_NOT_CHANGE</s:String>

  <!-- XML doc tags: render `<see cref="X" />` with a space before `/>`. -->
  <s:Boolean x:Key="/Default/CodeStyle/CSharpFormat/XMLDOC_FORMAT_ON_TYPING/@EntryValue">True</s:Boolean>
  <s:Boolean x:Key="/Default/CodeStyle/CSharpFormat/XMLDOC_KEEP_USER_LINEBREAKS/@EntryValue">True</s:Boolean>

  <!-- =============================================================== -->
  <!-- Inspection severities: elevate house-style violations.          -->
  <!-- =============================================================== -->
  <s:String x:Key="/Default/CodeInspection/Highlighting/InspectionSeverities/=ConvertIfStatementToReturnStatement/@EntryIndexedValue">SUGGESTION</s:String>
  <s:String x:Key="/Default/CodeInspection/Highlighting/InspectionSeverities/=InvertIf/@EntryIndexedValue">WARNING</s:String>
  <s:String x:Key="/Default/CodeInspection/Highlighting/InspectionSeverities/=ReplaceWithFieldKeyword/@EntryIndexedValue">DO_NOT_SHOW</s:String>
  <s:String x:Key="/Default/CodeInspection/Highlighting/InspectionSeverities/=ConvertToAutoProperty/@EntryIndexedValue">DO_NOT_SHOW</s:String>
  <s:String x:Key="/Default/CodeInspection/Highlighting/InspectionSeverities/=ConvertToAutoPropertyWhenPossible/@EntryIndexedValue">DO_NOT_SHOW</s:String>
  <s:String x:Key="/Default/CodeInspection/Highlighting/InspectionSeverities/=ConvertToAutoPropertyWithPrivateSetter/@EntryIndexedValue">DO_NOT_SHOW</s:String>
  <s:String x:Key="/Default/CodeInspection/Highlighting/InspectionSeverities/=UseCollectionExpression/@EntryIndexedValue">WARNING</s:String>
  <s:String x:Key="/Default/CodeInspection/Highlighting/InspectionSeverities/=ArrangeObjectCreationWhenTypeNotEvident/@EntryIndexedValue">SUGGESTION</s:String>
  <s:String x:Key="/Default/CodeInspection/Highlighting/InspectionSeverities/=ArrangeObjectCreationWhenTypeEvident/@EntryIndexedValue">WARNING</s:String>
  <s:String x:Key="/Default/CodeInspection/Highlighting/InspectionSeverities/=RedundantNameQualifier/@EntryIndexedValue">WARNING</s:String>
  <s:String x:Key="/Default/CodeInspection/Highlighting/InspectionSeverities/=RedundantUsingDirective/@EntryIndexedValue">WARNING</s:String>

  <!-- =============================================================== -->
  <!-- Folder excludes: never run cleanup on lifted upstream files.   -->
  <!-- =============================================================== -->
  <s:Boolean x:Key="/Default/CodeInspection/ExcludedFiles/FilesAndFoldersToSkip2/=third_005Fparty/@EntryIndexedValue">True</s:Boolean>
	<s:Boolean x:Key="/Default/UserDictionary/Words/=slnx/@EntryIndexedValue">True</s:Boolean>
</wpf:ResourceDictionary>
